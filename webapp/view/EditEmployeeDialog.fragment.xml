<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout.form">

    <Dialog
        title="{i18n>editEmployee}"
        contentWidth="600px"
        resizable="true"
        draggable="true">

        <content>
            <layout:SimpleForm
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                columnsXL="2" columnsL="2" columnsM="2">

                <layout:content>
                    <Label text="{i18n>firstName}" required="true" />
                    <Input value="{edit>/firstName}" placeholder="{i18n>firstName}" />

                    <Label text="{i18n>lastName}" required="true" />
                    <Input value="{edit>/lastName}" placeholder="{i18n>lastName}" />

                    <Label text="{i18n>email}" required="true" />
                    <Input value="{edit>/email}" type="Email" placeholder="name@example.com" />

                    <Label text="{i18n>department}" />
                    <Select selectedKey="{edit>/department}">
                        <core:Item key="Engineering" text="Engineering" />
                        <core:Item key="HR" text="HR" />
                        <core:Item key="Finance" text="Finance" />
                        <core:Item key="Sales" text="Sales" />
                        <core:Item key="Marketing" text="Marketing" />
                        <core:Item key="Operations" text="Operations" />
                        <core:Item key="IT" text="IT" />
                        <core:Item key="Legal" text="Legal" />
                    </Select>

                    <Label text="{i18n>jobTitle}" />
                    <Input value="{edit>/jobTitle}" placeholder="{i18n>jobTitle}" />

                    <Label text="{i18n>hireDate}" />
                    <DatePicker value="{edit>/hireDate}" valueFormat="yyyy-MM-dd" displayFormat="medium" />

                    <Label text="{i18n>salary}" />
                    <Input value="{edit>/salary}" type="Number" placeholder="0.00" />

                    <Label text="{i18n>phoneNumber}" />
                    <Input value="{edit>/phoneNumber}" type="Tel" placeholder="+1-555-0000" />

                    <Label text="{i18n>address}" />
                    <TextArea value="{edit>/address}" rows="2" growing="true" />

                    <Label text="{i18n>status}" />
                    <Select selectedKey="{edit>/status}">
                        <core:Item key="Active" text="{i18n>active}" />
                        <core:Item key="Inactive" text="{i18n>inactive}" />
                        <core:Item key="OnLeave" text="On Leave" />
                    </Select>
                </layout:content>
            </layout:SimpleForm>
        </content>

        <buttons>
            <Button text="{i18n>save}" type="Emphasized" press=".onEditSave" />
            <Button text="{i18n>cancel}" press=".onEditCancel" />
        </buttons>
    </Dialog>
</core:FragmentDefinition>
