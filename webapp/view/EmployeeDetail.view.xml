<mvc:View
    controllerName="com.hackathon.employeeui5.controller.EmployeeDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:layout="sap.ui.layout.form"
    displayBlock="true">

    <Page
        id="employeeDetailPage"
        title="{= ${firstName} + ' ' + ${lastName}}"
        showNavButton="true"
        navButtonPress=".onNavBack">

        <headerContent>
            <Button
                icon="sap-icon://edit"
                text="{i18n>edit}"
                type="Emphasized"
                press=".onEditPress" />
            <Button
                icon="sap-icon://delete"
                text="{i18n>delete}"
                type="Negative"
                press=".onDeletePress"
                class="sapUiSmallMarginBegin" />
        </headerContent>

        <content>
            <VBox class="sapUiMediumMargin">

                <ObjectHeader
                    title="{= ${firstName} + ' ' + ${lastName}}"
                    number="{salary}"
                    numberUnit="USD"
                    numberState="Success">
                    <attributes>
                        <ObjectAttribute title="{i18n>jobTitle}" text="{jobTitle}" />
                        <ObjectAttribute title="{i18n>department}" text="{department}" />
                        <ObjectAttribute title="{i18n>status}" text="{status}" />
                    </attributes>
                </ObjectHeader>

                <Panel headerText="{i18n>contactInfo}" expandable="true" expanded="true" class="sapUiSmallMarginTop">
                    <layout:SimpleForm layout="ResponsiveGridLayout"
                        labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12">
                        <layout:content>
                            <Label text="{i18n>email}" />
                            <Link text="{email}" href="mailto:{email}" />

                            <Label text="{i18n>phoneNumber}" />
                            <Text text="{phoneNumber}" />

                            <Label text="{i18n>address}" />
                            <Text text="{address}" />
                        </layout:content>
                    </layout:SimpleForm>
                </Panel>

                <Panel headerText="{i18n>employmentInfo}" expandable="true" expanded="true" class="sapUiSmallMarginTop">
                    <layout:SimpleForm layout="ResponsiveGridLayout"
                        labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12">
                        <layout:content>
                            <Label text="{i18n>hireDate}" />
                            <Text text="{
                                path: 'hireDate',
                                type: 'sap.ui.model.type.Date',
                                formatOptions: { style: 'long' }
                            }" />

                            <Label text="{i18n>salary}" />
                            <ObjectNumber
                                number="{salary}"
                                unit="USD"
                                state="Success" />
                        </layout:content>
                    </layout:SimpleForm>
                </Panel>
            </VBox>
        </content>
    </Page>
</mvc:View>
